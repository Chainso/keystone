{
  "name": "keystone-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Keystone Milestone 1 scaffold on Cloudflare Workers.",
  "scripts": {
    "predev": "npm run build:ui",
    "dev": "wrangler dev",
    "dev:ui": "vite build --watch",
    "dev:ui:serve": "vite dev --host 127.0.0.1",
    "dev:zellij": "bash ./scripts/open-ui-dev-workspace.sh",
    "build:ui": "vite build",
    "build": "npm run build:ui && wrangler deploy --dry-run --outdir .wrangler/deploy",
    "test": "vitest run",
    "test:security": "vitest run tests/lib/security-policy.test.ts",
    "test:workflows": "vitest run tests/http/app.test.ts tests/lib/workflow-ids.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.ui.json",
    "cf-typegen": "wrangler types",
    "db:migrate": "tsx src/lib/db/migrations.ts",
    "sandbox:smoke": "node --import tsx scripts/sandbox-smoke.ts",
    "sandbox:shell": "bash ./scripts/open-sandbox-shell.sh",
    "think:smoke": "node --import tsx scripts/think-smoke.ts",
    "run:local": "node --import tsx scripts/run-local.ts",
    "demo:ensure-project": "node --import tsx scripts/ensure-demo-project.ts",
    "demo:run": "node --import tsx scripts/demo-run.ts",
    "demo:run:think-live": "KEYSTONE_EXECUTION_ENGINE=think_live node --import tsx scripts/demo-run.ts",
    "demo:validate": "node --import tsx scripts/demo-validate.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@assistant-ui/react": "^0.12.25",
    "@assistant-ui/react-markdown": "^0.12.9",
    "@cloudflare/ai-chat": "^0.4.4",
    "@cloudflare/sandbox": "^0.8.10",
    "@cloudflare/shell": "^0.3.2",
    "@cloudflare/think": "^0.2.4",
    "@hookform/resolvers": "^5.2.2",
    "@platejs/autoformat": "^52.3.10",
    "@platejs/basic-nodes": "^52.3.10",
    "@platejs/basic-styles": "^52.3.10",
    "@platejs/code-block": "^52.3.16",
    "@platejs/floating": "^52.3.10",
    "@platejs/link": "^52.3.17",
    "@platejs/list-classic": "^52.3.10",
    "@platejs/markdown": "^52.3.22",
    "@platejs/math": "^52.3.10",
    "@platejs/resizable": "^52.3.10",
    "@platejs/selection": "^52.3.10",
    "@platejs/table": "^52.3.20",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@radix-ui/themes": "^3.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-table": "^8.21.3",
    "@udecode/cn": "^52.3.4",
    "agents": "^0.11.1",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "lodash": "^4.18.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "platejs": "^52.3.21",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.1",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  }
}

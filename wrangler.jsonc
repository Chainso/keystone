{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "keystone-cloudflare",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": ["nodejs_compat", "experimental"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/v1/*", "/internal/*", "/healthz"]
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./sandbox/Dockerfile",
      "instance_type": "lite",
      "max_instances": 4
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "RUN_COORDINATOR",
        "class_name": "RunCoordinatorDO"
      },
      {
        "name": "TASK_SESSION",
        "class_name": "TaskSessionDO"
      },
      {
        "name": "KEYSTONE_THINK_AGENT",
        "class_name": "KeystoneThinkAgent"
      },
      {
        "name": "SANDBOX",
        "class_name": "Sandbox"
      }
    ]
  },
  "workflows": [
    {
      "binding": "RUN_WORKFLOW",
      "name": "run-workflow",
      "class_name": "RunWorkflow"
    },
    {
      "binding": "TASK_WORKFLOW",
      "name": "task-workflow",
      "class_name": "TaskWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RunCoordinatorDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["TaskSessionDO", "Sandbox"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["KeystoneThinkAgent"]
    }
  ],
  "vars": {
    "KEYSTONE_DEV_TENANT_ID": "tenant-dev-local",
    "KEYSTONE_CHAT_COMPLETIONS_BASE_URL": "http://localhost:10531",
    "KEYSTONE_CHAT_COMPLETIONS_MODEL": "gpt-5.4"
  },
  "r2_buckets": [
    {
      "binding": "ARTIFACTS_BUCKET",
      "bucket_name": "keystone-artifacts-dev"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "00000000000000000000000000000000",
      "localConnectionString": "postgres://postgres:postgres@127.0.0.1:5432/keystone"
    }
  ]
}
